# Provider selection
  PROVIDER_NAME=openligadb
  PROVIDER_BASE_URL=https://www.openligadb.de

  # HTTP client
  UPSTREAM_TIMEOUT_S=10.0

  # Rate limiting: max upstream requests per second (0 disables)
  UPSTREAM_RATE_PER_SEC=5.0

  # Exponential backoff with jitter on transient upstream errors
  UPSTREAM_MAX_RETRIES=3
  UPSTREAM_BACKOFF_BASE_S=0.2

  # Logging
  LOG_BODY_MAX_CHARS=512